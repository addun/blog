---
interface Props {
  /** The Mermaid diagram definition. Pass it as a template literal so arrows
   *  like `-->` aren't mangled by MDX, e.g. <Mermaid chart={`flowchart TD ...`} /> */
  chart: string;
  className?: string;
}

const { chart, className } = Astro.props;
---

<pre class={`mermaid not-prose flex justify-center my-10 ${className ?? ""}`} data-mermaid>{chart}</pre>

<script>
  import mermaid from "mermaid";

  const render = async () => {
    const nodes = document.querySelectorAll<HTMLElement>("pre[data-mermaid]");
    if (nodes.length === 0) return;

    const isDark = document.documentElement.classList.contains("dark");
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? "dark" : "default",
    });

    // Re-render from the original source kept in data-source on re-runs.
    nodes.forEach((node) => {
      if (node.dataset.source) {
        node.innerHTML = node.dataset.source;
        node.removeAttribute("data-processed");
      } else {
        node.dataset.source = node.textContent ?? "";
      }
    });

    await mermaid.run({ nodes });
  };

  render();
  // Re-render after client-side navigations (Astro view transitions).
  document.addEventListener("astro:after-swap", render);
</script>
